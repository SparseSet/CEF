AWS_DEFAULT_REGION="us-east-1"

CEF_ARTIFACT_BUCKET="prototwin-build-artifacts"
CEF_S3_PREFIX="cef-builds"

# Optional. Defaults are usually fine.
# CEF_BRANCH="7204"
# CEF_DOWNLOAD_DIR="/tmp/cef"
# CEF_BUILD_DIR="/tmp/cef-artifacts"
# Leave unset for target-specific defaults:
# - true for linux-x64 and macos-arm64
# - false for linux-arm64
# CEF_WITH_PGO_PROFILES="false"
